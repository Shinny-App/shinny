# HerdOS Runner — project customization
# This file is yours to customize — herd init will never overwrite it.
# Add project-specific tools, languages, and dependencies below.
#
# The base image provides: GitHub Actions runner, Claude Code, Herd CLI,
# curl, jq, git, gh, and Node.js.

FROM herd-runner-base

# The base image runs as the 'runner' user. Switch to root to install
# packages, then switch back when done.
USER root

# Examples — uncomment what your project needs:
#
# Go
# RUN apt-get update && apt-get install -y golang-go && rm -rf /var/lib/apt/lists/*
#
# Python
# RUN apt-get update && apt-get install -y python3 python3-pip && rm -rf /var/lib/apt/lists/*
#
# Rust
# RUN curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh -s -- -y

# Ruby 4.0.2
RUN apt-get update && apt-get install -y \
      build-essential libssl-dev libreadline-dev zlib1g-dev \
      libsqlite3-dev libyaml-dev libffi-dev \
    && rm -rf /var/lib/apt/lists/* \
    && curl -fsSL https://cache.ruby-lang.org/pub/ruby/4.0/ruby-4.0.2.tar.gz -o /tmp/ruby.tar.gz \
    && tar -xzf /tmp/ruby.tar.gz -C /tmp \
    && cd /tmp/ruby-4.0.2 \
    && ./configure --prefix=/usr/local --disable-install-doc \
    && make -j"$(nproc)" \
    && make install \
    && rm -rf /tmp/ruby.tar.gz /tmp/ruby-4.0.2

RUN gem install bundler --no-document && gem install rails -v '~> 8.1.2' --no-document

# Pre-install application gems so workers don't compile native extensions at runtime
COPY Gemfile Gemfile.lock ./
RUN bundle install

USER runner
