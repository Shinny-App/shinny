# HerdOS runner environment
# Copy this file to .env and fill in your values:
#   cp .env.herd.example .env

# GitHub Personal Access Token (required)
# Needs 'repo' scope for private repos, or fine-grained with Actions read/write
GITHUB_TOKEN=

# Claude Code authentication (choose one):

# Option 1: OAuth token (uses your Pro/Max subscription, no per-token cost)
# Generate with: claude setup-token
CLAUDE_CODE_OAUTH_TOKEN=

# Option 2: API key (pay-per-token via console.anthropic.com)
# ANTHROPIC_API_KEY=

# Herd version for runner containers (optional — defaults to latest)
# Set this to pin a specific version, e.g.:
# HERD_VERSION=v0.1.0-rc.2

# Enable agent debug logging (optional — dumps Claude Code debug logs on failure)
# HERD_AGENT_DEBUG=true
