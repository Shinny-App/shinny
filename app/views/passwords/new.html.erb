<div class="mx-auto max-w-sm">
  <h1 class="text-2xl font-bold text-center mb-8">Reset your password</h1>

  <%= form_with url: passwords_path do |form| %>
    <div class="mb-6">
      <%= form.label :email_address, "Email address", class: "block text-sm font-medium mb-1" %>
      <%= form.email_field :email_address, required: true, autofocus: true, autocomplete: "username",
          class: "w-full rounded-md border border-gray-300 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500" %>
    </div>

    <%= form.submit "Send password reset instructions", class: "w-full rounded-md bg-blue-600 px-4 py-2 text-sm font-semibold text-white hover:bg-blue-500 focus:outline-none focus:ring-2 focus:ring-blue-500" %>
  <% end %>

  <p class="mt-4 text-center text-sm text-gray-600">
    <%= link_to "Back to sign in", new_session_path, class: "text-blue-600 hover:underline" %>
  </p>
</div>
