<div class="mx-auto max-w-sm">
  <h1 class="text-2xl font-bold text-center mb-8">Choose a new password</h1>

  <%= form_with url: password_path(params[:token]), method: :patch do |form| %>
    <div class="mb-4">
      <%= form.label :password, "New password", class: "block text-sm font-medium mb-1" %>
      <%= form.password_field :password, required: true, autocomplete: "new-password",
          class: "w-full rounded-md border border-gray-300 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500" %>
    </div>

    <div class="mb-6">
      <%= form.label :password_confirmation, "Confirm new password", class: "block text-sm font-medium mb-1" %>
      <%= form.password_field :password_confirmation, required: true, autocomplete: "new-password",
          class: "w-full rounded-md border border-gray-300 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500" %>
    </div>

    <%= form.submit "Save password", class: "w-full rounded-md bg-blue-600 px-4 py-2 text-sm font-semibold text-white hover:bg-blue-500 focus:outline-none focus:ring-2 focus:ring-blue-500" %>
  <% end %>
</div>
