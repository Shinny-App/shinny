<div class="mx-auto max-w-sm">
  <h1 class="text-2xl font-bold text-center mb-8">Create your account</h1>

  <% if @user.errors.any? %>
    <div class="mb-4 rounded-md bg-red-50 p-4">
      <ul class="list-disc list-inside text-sm text-red-700">
        <% @user.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <%= form_with model: @user, url: registration_path do |form| %>
    <div class="mb-4">
      <%= form.label :display_name, "Display name", class: "block text-sm font-medium mb-1" %>
      <%= form.text_field :display_name, required: true, autofocus: true, autocomplete: "name",
          class: "w-full rounded-md border border-gray-300 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500" %>
    </div>

    <div class="mb-4">
      <%= form.label :email_address, "Email address", class: "block text-sm font-medium mb-1" %>
      <%= form.email_field :email_address, required: true, autocomplete: "username",
          class: "w-full rounded-md border border-gray-300 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500" %>
    </div>

    <div class="mb-4">
      <%= form.label :password, class: "block text-sm font-medium mb-1" %>
      <%= form.password_field :password, required: true, autocomplete: "new-password",
          class: "w-full rounded-md border border-gray-300 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500" %>
    </div>

    <div class="mb-6">
      <%= form.label :password_confirmation, "Confirm password", class: "block text-sm font-medium mb-1" %>
      <%= form.password_field :password_confirmation, required: true, autocomplete: "new-password",
          class: "w-full rounded-md border border-gray-300 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500" %>
    </div>

    <%= form.submit "Create account", class: "w-full rounded-md bg-blue-600 px-4 py-2 text-sm font-semibold text-white hover:bg-blue-500 focus:outline-none focus:ring-2 focus:ring-blue-500" %>
  <% end %>

  <p class="mt-4 text-center text-sm text-gray-600">
    Already have an account?
    <%= link_to "Sign in", new_session_path, class: "text-blue-600 hover:underline" %>
  </p>
</div>
